BOT_TOKEN=
APP_ID=
GUILD_ID=
HEALTH_PORT=3002

# Ollama endpoint — ai-stack container (PCT 200)
OLLAMA_HOST=http://192.168.1.39:11434
OLLAMA_MODEL=qwen2.5:14b

# Summary schedule: default 22:00 ICT. Expressed as cron in Asia/Bangkok timezone.
SUMMARY_CRON=0 22 * * *

# Name of the Discord category where the cross-project master summary is posted
MASTER_CATEGORY=general

# ── Meeting recording (voice transcription) ──────────────────────────────────
# OpenAI Whisper API key — required for /meeting start transcription
OPENAI_API_KEY=

# Override to point at a self-hosted Whisper-compatible endpoint instead
# e.g. http://192.168.1.39:9000/v1/audio/transcriptions (faster-whisper-server)
# WHISPER_URL=

# BCP-47 language hint for Whisper (e.g. th, en). Leave unset for auto-detect.
# WHISPER_LANG=th
